---
import BaseHead from "./BaseHead.astro";
import { languages, type Lang } from "../i18n/ui";
import { useTranslations, isRtl, localizedPath } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const dir = isRtl(lang) ? "rtl" : "ltr";

const APP_URL = "https://app.lernedeutschmituns.com/";
---

<!doctype html>
<html lang={t.htmlLang} dir={dir}>
  <head>
    <BaseHead title={t.title} description={t.description} />
  </head>
  <body>
    <!-- NAV -->
    <nav>
      <a href={localizedPath(lang)} class="logo">🇩🇪 Deutsch Lernen</a>
      <div class="nav-links">
        <a href="#features">{t.nav.features}</a>
        <a href="#how-it-works">{t.nav.how}</a>
        <a href="/blog">{t.nav.blog}</a>

        <!-- LANGUAGE SWITCHER -->
        <div class="lang-switcher">
          {
            (Object.keys(languages) as Lang[]).map((code) => (
              <a
                href={localizedPath(code)}
                class:list={["lang-link", { active: code === lang }]}
                lang={code}
              >
                {languages[code]}
              </a>
            ))
          }
        </div>

        <a href={APP_URL} class="btn-outline">{t.nav.login}</a>
        <a href={APP_URL} class="btn-primary">{t.nav.getStarted}</a>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-badge">{t.hero.badge}</div>
      <h1>{t.hero.title1}<br /><span class="accent">{t.hero.title2}</span></h1>
      <p class="hero-sub">{t.hero.sub}</p>
      <div class="hero-cta">
        <a href={APP_URL} class="btn-primary btn-lg">{t.hero.ctaPrimary}</a>
        <a href="#features" class="btn-ghost">{t.hero.ctaGhost}</a>
      </div>
      <div class="hero-stats">
        {
          t.hero.stats.map((s, i) => (
            <>
              {i > 0 && <div class="stat-sep">·</div>}
              <div class="stat">
                <strong>{s.strong}</strong> {s.label}
              </div>
            </>
          ))
        }
      </div>
    </section>

    <!-- FEATURES -->
    <section id="features" class="features">
      <div class="section-label">{t.features.label}</div>
      <h2>{t.features.title}</h2>
      <div class="cards">
        {
          t.features.cards.map((card) => (
            <div class="card">
              <div class="card-icon">{card.icon}</div>
              <h3>{card.title}</h3>
              <p>{card.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="how-it-works" class="features">
      <div class="section-label">{t.how.label}</div>
      <h2>{t.how.title}</h2>
      <div class="steps">
        {
          t.how.steps.map((step, i) => (
            <>
              {i > 0 && <div class="step-arrow">→</div>}
              <div class="step">
                <div class="step-num">{step.num}</div>
                <h3>{step.title}</h3>
                <p>{step.desc}</p>
              </div>
            </>
          ))
        }
      </div>
    </section>

    <!-- CTA BANNER -->
    <section class="cta-banner">
      <h2>{t.cta.title}</h2>
      <p>{t.cta.sub}</p>
      <a href={APP_URL} class="btn-primary btn-lg">{t.cta.btn}</a>
    </section>

    <!-- FOOTER -->
    <footer>
      <span>© {new Date().getFullYear()} Deutsch Lernen</span>
      <span class="footer-sep">·</span>
      <a href={APP_URL}>{t.footer.app}</a>
      <span class="footer-sep">·</span>
      <a href={localizedPath(lang, "/about")}>{t.footer.about}</a>
    </footer>
  </body>
</html>

<style>
  /* ── Reset / base ── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  :root {
    --black: #0f1219;
    --white: #ffffff;
    --gold: #f5c518;
    --gold-dark: #c49b10;
    --red: #dd0000;
    --gray: #6c7390;
    --gray-light: #f4f5f8;
    --radius: 14px;
    --max: 1100px;
  }

  body {
    margin: 0;
    background: var(--white);
    color: var(--black);
    font-family: var(--font-atkinson), system-ui, sans-serif;
    font-size: 18px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* ── Nav ── */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 2rem;
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    z-index: 100;
  }

  .logo {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: 0.95rem;
  }

  .nav-links a:not(.btn-outline):not(.btn-primary):not(.lang-link) {
    color: var(--gray);
    transition: color 0.15s;
  }
  .nav-links a:not(.btn-outline):not(.btn-primary):not(.lang-link):hover {
    color: var(--black);
  }

  /* ── Language switcher ── */
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-inline: 0.75rem;
    border-inline: 1px solid rgba(0, 0, 0, 0.1);
  }
  .lang-link {
    font-size: 0.85rem;
    color: var(--gray);
    transition: color 0.15s;
  }
  .lang-link:hover {
    color: var(--black);
  }
  .lang-link.active {
    color: var(--black);
    font-weight: 700;
  }

  /* ── Buttons ── */
  .btn-primary {
    background: var(--black);
    color: var(--white) !important;
    padding: 0.55rem 1.2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    transition:
      background 0.15s,
      transform 0.1s;
  }
  .btn-primary:hover {
    background: #2a2f3e;
    transform: translateY(-1px);
  }

  .btn-outline {
    border: 1.5px solid #d1d5db;
    color: var(--black) !important;
    padding: 0.5rem 1.1rem;
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.9rem;
    transition: border-color 0.15s;
  }
  .btn-outline:hover {
    border-color: var(--black);
  }

  .btn-lg {
    padding: 0.85rem 2rem !important;
    font-size: 1rem !important;
    border-radius: 10px !important;
  }

  .btn-ghost {
    color: var(--gray);
    font-size: 1rem;
    transition: color 0.15s;
  }
  .btn-ghost:hover {
    color: var(--black);
  }

  /* ── Hero ── */
  .hero {
    max-width: var(--max);
    margin: 0 auto;
    padding: 6rem 2rem 5rem;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: var(--gold);
    color: var(--black);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 1.2rem;
    color: var(--black);
  }

  .accent {
    color: var(--red);
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--gray);
    max-width: 560px;
    margin: 0 auto 2.2rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--gray);
  }
  .stat strong {
    color: var(--black);
  }
  .stat-sep {
    opacity: 0.4;
  }

  /* ── Section shared ── */
  .section-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 0.6rem;
  }

  .features,
  .how {
    max-width: var(--max);
    margin: 0 auto;
    padding: 5rem 2rem;
  }

  .features h2,
  .how h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    margin: 0 0 2.8rem;
    color: var(--black);
  }

  /* ── Feature cards ── */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .card {
    background: var(--gray-light);
    border-radius: var(--radius);
    padding: 1.8rem;
    transition:
      transform 0.18s,
      box-shadow 0.18s;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }

  .card-icon {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
  }
  .card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    color: var(--black);
  }
  .card p {
    font-size: 0.95rem;
    color: var(--gray);
    margin: 0;
  }

  /* ── How it works ── */
  .how {
    background: var(--gray-light);
    max-width: 100%;
    border-radius: 0;
  }
  .how > * {
    max-width: var(--max);
    margin-left: auto;
    margin-right: auto;
  }
  .how h2 {
    max-width: var(--max);
  }

  .steps {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    max-width: var(--max);
    margin: 0 auto;
  }

  .step {
    flex: 1;
    min-width: 220px;
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.8rem;
  }

  .step-num {
    font-size: 2rem;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .step h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    color: var(--black);
  }
  .step p {
    font-size: 0.95rem;
    color: var(--gray);
    margin: 0;
  }

  .step-arrow {
    font-size: 1.5rem;
    color: var(--gray);
    opacity: 0.4;
    padding-top: 2.2rem;
    flex-shrink: 0;
  }

  /* Flip directional arrows in RTL */
  :global([dir="rtl"]) .step-arrow {
    transform: scaleX(-1);
  }

  /* ── CTA banner ── */
  .cta-banner {
    background: var(--black);
    color: var(--white);
    text-align: center;
    padding: 5rem 2rem;
  }

  .cta-banner h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    margin: 0 0 0.75rem;
    color: var(--white);
  }

  .cta-banner p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.05rem;
    margin: 0 0 2rem;
  }

  .cta-banner .btn-primary {
    background: var(--gold);
    color: var(--black) !important;
  }
  .cta-banner .btn-primary:hover {
    background: var(--gold-dark);
  }

  /* ── Footer ── */
  footer {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    padding: 2rem;
    font-size: 0.9rem;
    color: var(--gray);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  footer a:hover {
    color: var(--black);
  }
  .footer-sep {
    opacity: 0.4;
  }

  /* ── Responsive ── */
  @media (max-width: 820px) {
    .nav-links a:not(.btn-primary):not(.lang-link) {
      display: none;
    }
    .lang-switcher {
      border: none;
      padding-inline: 0;
    }
  }
  @media (max-width: 680px) {
    nav {
      padding: 1rem;
    }
    .step-arrow {
      display: none;
    }
    .hero {
      padding: 4rem 1.25rem 3rem;
    }
  }
</style>
