---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const langLabels: Record<string, string> = {
	en: 'English',
	fr: 'Français',
	ar: 'العربية',
};

// Parse lang and topic from the post id (e.g. "en/resources/my-post")
function parseMeta(id: string) {
	const parts = id.split('/');
	const lang = parts.length >= 2 ? parts[0] : 'en';
	const topic = parts.length >= 3 ? parts[1] : null;
	return { lang, topic };
}

const grouped = Object.entries(langLabels).map(([lang, label]) => ({
	lang,
	label,
	posts: allPosts.filter((p) => parseMeta(p.id).lang === lang),
})).filter((g) => g.posts.length > 0);

// Posts without a language prefix go in a separate "Other" group
const ungrouped = allPosts.filter((p) => {
	const { lang } = parseMeta(p.id);
	return !langLabels[lang];
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em;
			}
			.lang-section {
				margin-bottom: 3rem;
			}
			.lang-heading {
				font-size: 1.4rem;
				font-weight: 700;
				margin: 0 0 1.2rem;
				padding-bottom: 0.4rem;
				border-bottom: 2px solid #eee;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 1.5rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 0.75rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
				width: 100%;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0 0 0.25rem;
				color: rgb(var(--black));
				line-height: 1.3;
				font-size: 1rem;
				font-weight: 600;
			}
			.date {
				margin: 0 0 0.25rem;
				color: rgb(var(--gray));
				font-size: 0.85rem;
			}
			.topic-tag {
				display: inline-block;
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				padding: 0.15rem 0.55rem;
				border-radius: 999px;
				background: #f4f5f8;
				color: #6c7390;
			}
			ul li a:hover .title,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.75rem;
				}
				ul li {
					width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{
				grouped.map(({ lang, label, posts }) => (
					<section class="lang-section">
						<h2 class="lang-heading">{label}</h2>
						<ul>
							{posts.map((post) => {
								const { topic } = parseMeta(post.id);
								return (
									<li>
										<a href={`/blog/${post.id}/`}>
											{post.data.heroImage && (
												<Image width={720} height={360} src={post.data.heroImage} alt="" />
											)}
											<h4 class="title">{post.data.title}</h4>
											<p class="date">
												<FormattedDate date={post.data.pubDate} />
											</p>
											{topic && <span class="topic-tag">{topic}</span>}
										</a>
									</li>
								);
							})}
						</ul>
					</section>
				))
			}

			{
				ungrouped.length > 0 && (
					<section class="lang-section">
						<h2 class="lang-heading">Other</h2>
						<ul>
							{ungrouped.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<Image width={720} height={360} src={post.data.heroImage} alt="" />
										)}
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>
