---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const APP_URL = '#';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>

    <!-- NAV -->
    <nav>
      <a href="/" class="logo">🇩🇪 Deutsch Lernen</a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#how-it-works">How it works</a>
        <a href={APP_URL} class="btn-outline">Log in</a>
        <a href={APP_URL} class="btn-primary">Get started free</a>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-badge">✦ Free to start</div>
      <h1>Learn German,<br /><span class="accent">the smart way.</span></h1>
      <p class="hero-sub">
        Vocabulary drills, grammar exercises, reading stories, and a leaderboard
        to keep you motivated — all in one place.
      </p>
      <div class="hero-cta">
        <a href={APP_URL} class="btn-primary btn-lg">Start learning for free</a>
        <a href="#features" class="btn-ghost">See what's inside →</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><strong>4</strong> learning modules</div>
        <div class="stat-sep">·</div>
        <div class="stat"><strong>A1 → C1</strong> all levels</div>
        <div class="stat-sep">·</div>
        <div class="stat"><strong>Google</strong> sign-in</div>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="features" class="features">
      <div class="section-label">What you get</div>
      <h2>Everything you need to master German</h2>
      <div class="cards">
        <div class="card">
          <div class="card-icon">📚</div>
          <h3>Vocabulary</h3>
          <p>Structured word lists organized by level and topic. Build your vocabulary step by step from A1 to C1.</p>
        </div>
        <div class="card">
          <div class="card-icon">✏️</div>
          <h3>Grammar Exercises</h3>
          <p>Interactive exercises covering cases, verb conjugations, sentence structure, and more.</p>
        </div>
        <div class="card">
          <div class="card-icon">📖</div>
          <h3>Reading Stories</h3>
          <p>Short stories with audio support, graded by difficulty so you always read at the right level.</p>
        </div>
        <div class="card">
          <div class="card-icon">📈</div>
          <h3>Progress Tracking</h3>
          <p>See your streaks, completed lessons, and time spent. A leaderboard keeps the competitive edge alive.</p>
        </div>
        <div class="card">
          <div class="card-icon">👩‍🏫</div>
          <h3>Teacher Support</h3>
          <p>Teachers can assign exercises, track student progress, and manage their class — all from one dashboard.</p>
        </div>
        <div class="card">
          <div class="card-icon">🔐</div>
          <h3>Easy Sign-in</h3>
          <p>Log in with your Google account in one click. No password to remember, no hassle.</p>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="how-it-works" class="how">
      <div class="section-label">How it works</div>
      <h2>Three steps to fluency</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num">01</div>
          <h3>Create your account</h3>
          <p>Sign up in seconds with Google or email. Pick your current level and we'll build the right path for you.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-num">02</div>
          <h3>Pick a module</h3>
          <p>Choose vocabulary, grammar, or reading — or follow the guided course that mixes all three.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-num">03</div>
          <h3>Track your growth</h3>
          <p>Complete exercises, earn points, climb the leaderboard, and watch your German get better every day.</p>
        </div>
      </div>
    </section>

    <!-- CTA BANNER -->
    <section class="cta-banner">
      <h2>Ready to speak German?</h2>
      <p>Join learners already improving their German every day.</p>
      <a href={APP_URL} class="btn-primary btn-lg">Get started — it's free</a>
    </section>

    <!-- FOOTER -->
    <footer>
      <span>© {new Date().getFullYear()} Deutsch Lernen</span>
      <span class="footer-sep">·</span>
      <a href={APP_URL}>App</a>
      <span class="footer-sep">·</span>
      <a href="/about">About</a>
    </footer>

  </body>
</html>

<style>
  /* ── Reset / base ── */
  *, *::before, *::after { box-sizing: border-box; }

  :root {
    --black: #0f1219;
    --white: #ffffff;
    --gold: #f5c518;
    --gold-dark: #c49b10;
    --red: #dd0000;
    --gray: #6c7390;
    --gray-light: #f4f5f8;
    --radius: 14px;
    --max: 1100px;
  }

  body {
    margin: 0;
    background: var(--white);
    color: var(--black);
    font-family: var(--font-atkinson), system-ui, sans-serif;
    font-size: 18px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }

  /* ── Nav ── */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 2rem;
    position: sticky;
    top: 0;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,0,0,0.06);
    z-index: 100;
  }

  .logo {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: 0.95rem;
  }

  .nav-links a:not(.btn-outline):not(.btn-primary) {
    color: var(--gray);
    transition: color 0.15s;
  }
  .nav-links a:not(.btn-outline):not(.btn-primary):hover { color: var(--black); }

  /* ── Buttons ── */
  .btn-primary {
    background: var(--black);
    color: var(--white) !important;
    padding: 0.55rem 1.2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.15s, transform 0.1s;
  }
  .btn-primary:hover { background: #2a2f3e; transform: translateY(-1px); }

  .btn-outline {
    border: 1.5px solid #d1d5db;
    color: var(--black) !important;
    padding: 0.5rem 1.1rem;
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.9rem;
    transition: border-color 0.15s;
  }
  .btn-outline:hover { border-color: var(--black); }

  .btn-lg {
    padding: 0.85rem 2rem !important;
    font-size: 1rem !important;
    border-radius: 10px !important;
  }

  .btn-ghost {
    color: var(--gray);
    font-size: 1rem;
    transition: color 0.15s;
  }
  .btn-ghost:hover { color: var(--black); }

  /* ── Hero ── */
  .hero {
    max-width: var(--max);
    margin: 0 auto;
    padding: 6rem 2rem 5rem;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: var(--gold);
    color: var(--black);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 1.2rem;
    color: var(--black);
  }

  .accent { color: var(--red); }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--gray);
    max-width: 560px;
    margin: 0 auto 2.2rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--gray);
  }
  .stat strong { color: var(--black); }
  .stat-sep { opacity: 0.4; }

  /* ── Section shared ── */
  .section-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 0.6rem;
  }

  .features, .how {
    max-width: var(--max);
    margin: 0 auto;
    padding: 5rem 2rem;
  }

  .features h2, .how h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    margin: 0 0 2.8rem;
    color: var(--black);
  }

  /* ── Feature cards ── */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .card {
    background: var(--gray-light);
    border-radius: var(--radius);
    padding: 1.8rem;
    transition: transform 0.18s, box-shadow 0.18s;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
  }

  .card-icon { font-size: 1.8rem; margin-bottom: 0.75rem; }
  .card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    color: var(--black);
  }
  .card p { font-size: 0.95rem; color: var(--gray); margin: 0; }

  /* ── How it works ── */
  .how { background: var(--gray-light); max-width: 100%; border-radius: 0; }
  .how > * { max-width: var(--max); margin-left: auto; margin-right: auto; }
  .how h2 { max-width: var(--max); }

  .steps {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    max-width: var(--max);
    margin: 0 auto;
  }

  .step {
    flex: 1;
    min-width: 220px;
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.8rem;
  }

  .step-num {
    font-size: 2rem;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .step h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    color: var(--black);
  }
  .step p { font-size: 0.95rem; color: var(--gray); margin: 0; }

  .step-arrow {
    font-size: 1.5rem;
    color: var(--gray);
    opacity: 0.4;
    padding-top: 2.2rem;
    flex-shrink: 0;
  }

  /* ── CTA banner ── */
  .cta-banner {
    background: var(--black);
    color: var(--white);
    text-align: center;
    padding: 5rem 2rem;
  }

  .cta-banner h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    margin: 0 0 0.75rem;
    color: var(--white);
  }

  .cta-banner p {
    color: rgba(255,255,255,0.6);
    font-size: 1.05rem;
    margin: 0 0 2rem;
  }

  .cta-banner .btn-primary {
    background: var(--gold);
    color: var(--black) !important;
  }
  .cta-banner .btn-primary:hover { background: var(--gold-dark); }

  /* ── Footer ── */
  footer {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    padding: 2rem;
    font-size: 0.9rem;
    color: var(--gray);
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  footer a:hover { color: var(--black); }
  .footer-sep { opacity: 0.4; }

  /* ── Responsive ── */
  @media (max-width: 680px) {
    nav { padding: 1rem; }
    .nav-links a:not(.btn-primary) { display: none; }
    .step-arrow { display: none; }
    .hero { padding: 4rem 1.25rem 3rem; }
  }
</style>
